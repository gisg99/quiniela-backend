# Copia este archivo a ".env" y rellena tus valores

# --- Conexión a Postgres ---
# Opción A: una sola URL de conexión
DATABASE_URL=postgresql://mageova:jJD1Jz9wC3QJRdGNFlq5pgois0mSJCwl@dpg-d8gvcp5dt1ts73fp3a30-a.oregon-postgres.render.com/quiniela_mageova

# Opción B (alternativa): variables sueltas (se usan si no defines DATABASE_URL)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=quiniela_mageova

# Pon en "true" si tu Postgres es remoto y requiere SSL (Render, Supabase, Neon, etc.)
PGSSL=true

# --- App ---
PORT=4000

# Contraseña de administrador para capturar resultados desde la pantalla Admin.
# Si la dejas vacía, NO se exige contraseña (modo abierto, útil en desarrollo).
ADMIN_PASSWORD='M4g30v42026#'

# Premio total a repartir (en USD)
PRIZE_TOTAL=6000

# ID de esta instancia de quiniela (1 = original, 2 = familia, etc.)
# Cada deploy del backend debe tener su propio QUINIELA_ID distinto.
QUINIELA_ID=3

# --- Sincronización de resultados/cruces del Mundial 2026 ---
# Fuente de datos: 'openfootball' (gratis, sin key) o 'apifootball' (requiere
# plan de pago para la season 2026; el plan Free NO cubre 2026).
SYNC_PROVIDER=openfootball

# (Opcional) URL del JSON de openfootball. Por defecto usa el del repo oficial.
# OPENFOOTBALL_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json

# (Opcional) Solo si algún día usas SYNC_PROVIDER=apifootball con plan de pago.
APIFOOTBALL_KEY=1bf9e61a731290504bd63226c7ee77be
APIFOOTBALL_LEAGUE=1
APIFOOTBALL_SEASON=2026

# Token para que un Cron Job (p. ej. de Render) pueda llamar a POST /api/sync
# sin la contraseña de admin. Inventa una cadena larga y aleatoria.
SYNC_CRON_TOKEN=